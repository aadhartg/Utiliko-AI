# =========================================
# Utiliko AI Workflow + LMS — Environment
# =========================================
# Copy this to data/.env and fill in values

# ----- OpenAI (required for AI features) -----
OPENAI_API_KEY=sk-...your-key-here...

# ----- PostgreSQL -----
DATABASE_URL=postgresql+asyncpg://utiliko:utiliko_pass@db:5432/utiliko_db
SYNC_DATABASE_URL=postgresql://utiliko:utiliko_pass@db:5432/utiliko_db

# ----- Redis (background jobs / cache) -----
REDIS_URL=redis://redis:6379/0

# ----- App -----
SECRET_KEY=change-me-in-production-32chars-min
ENVIRONMENT=development
LOG_LEVEL=INFO

# ----- ML Model -----
ML_MODEL_PATH=ml/models/lead_scorer.joblib

# ----- LMS -----
CERT_STORAGE_PATH=static/certificates
BADGE_STORAGE_PATH=static/badges

# ----- CORS (comma-separated) -----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
