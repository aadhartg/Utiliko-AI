# =========================================
# Utiliko AI Workflow + LMS — Environment
# =========================================
# Copy this to data/.env and fill in values

# ----- OpenAI (required for AI features) -----
OPENAI_API_KEY=sk-...your-key-here...

# ----- PostgreSQL -----
DB_USER=utiliko
DB_PASSWORD=utiliko_pass
DB_NAME=utiliko_db1
DB_HOST=db
DATABASE_URL=postgresql+asyncpg://utiliko:utiliko_pass@db:5432/utiliko_db

# ----- Redis (background jobs / cache) -----
REDIS_URL=redis://utiliko-redis:6379/0
CELERY_BROKER_URL = redis://utiliko-redis:6379/1
CELERY_RESULT_BACKEND = redis://utiliko-redis:6379/2

# ----- App -----
APP = Utiliko AI Platform
PYTHON_ENV = development
HOST=0.0.0.0
PORT=8000
PYTHONPATH=.
SECRET_KEY = change-me-in-production-32chars-min
LOG_LEVEL = info
PYTHON_WORKER = 4
SCHEDULER_ENABLED = true

# ----- ML Model -----
ML_MODEL_PATH=ml/models/lead_scorer.joblib

# ----- LMS -----
CERT_STORAGE_PATH=static/certificates
BADGE_STORAGE_PATH=static/badges

# ----- CORS (comma-separated) -----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
